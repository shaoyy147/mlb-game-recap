<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MLB Replay Index</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-gray-100 py-10 font-sans text-gray-900">
    <main class="mx-auto max-w-4xl px-4">
        <header class="mb-8 rounded-2xl bg-white p-6 shadow-sm">
            <h1 class="text-3xl font-black">MLB Replay</h1>
            <p class="mt-2 text-sm text-gray-600">最近两周已完成比赛</p>
            <p class="mt-1 text-xs text-gray-500">Generated at {{ generated_at }}</p>
        </header>

        <section class="rounded-2xl bg-white p-6 shadow-sm">
            {% if grouped_records %}
            <div class="flex flex-col gap-8">
                {% for group in grouped_records %}
                <div>
                    <h2 class="mb-3 text-2xl font-medium tracking-tight text-gray-900">{{ group.official_date }}</h2>
                    <div class="flex flex-col divide-y divide-gray-200">
                        {% for record in group.records %}
                        <a href="{{ record.html_path }}" class="flex flex-col gap-2 py-4 transition hover:bg-gray-50 first:pt-0 last:pb-0">
                            <div class="flex items-start justify-between gap-4">
                                <div class="min-w-0">
                                    <div class="text-lg font-bold">{{ record.away_label }} @ {{ record.home_label }}</div>
                                    <div class="text-sm text-gray-600">{{ record.official_date }}{% if record.venue_name %} · {{ record.venue_name }}{% else %} · Final{% endif %}</div>
                                    <div class="text-xs text-gray-500">{{ record.away_name }} at {{ record.home_name }}</div>
                                </div>
                                <div class="shrink-0 text-left text-xs text-gray-600">
                                    <div><span class="font-mono text-gray-500">{{ record.away_label }} SP:</span> <span class="text-sm font-bold text-gray-800">{{ record.away_starting_pitcher }}</span></div>
                                    <div><span class="font-mono text-gray-500">{{ record.home_label }} SP:</span> <span class="text-sm font-bold text-gray-800">{{ record.home_starting_pitcher }}</span></div>
                                </div>
                            </div>
                        </a>
                        {% endfor %}
                    </div>
                </div>
                {% endfor %}
            </div>
            {% else %}
            <p class="text-sm text-gray-600">最近两周没有已完成比赛。</p>
            {% endif %}
        </section>
    </main>
</body>
</html>
