<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page_title }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .badge-blue {
            border-color: #005a9c;
            color: #005a9c;
        }
    </style>
</head>
<body class="min-h-screen bg-gray-50 py-8 font-sans text-gray-900">
    <div class="mx-auto flex max-w-md flex-col gap-8">
        <div class="rounded-xl bg-white p-6 shadow-sm">
            <div class="flex items-center justify-center rounded-lg bg-gray-200 py-3 shadow-sm">
                <div class="text-xl font-black tracking-wider text-gray-900">
                    {{ away_label }} <span class="mx-2 font-medium text-gray-500">@</span> {{ home_label }}
                </div>
            </div>

            <h2 class="mb-4 mt-5 text-center text-xs font-bold uppercase tracking-widest text-gray-400">Starting Pitchers</h2>
            <div class="grid grid-cols-2 gap-4 px-1">
                <div class="flex flex-col items-center text-center">
                    <span class="mb-2 text-[11px] font-bold tracking-wider text-gray-500">{{ starting_pitchers.away.label }}</span>
                    {% if starting_pitchers.away.avatar_url %}
                    <img src="{{ starting_pitchers.away.avatar_url }}" alt="{{ starting_pitchers.away.full_name }}" class="mb-2 h-[52px] w-[52px] rounded-full bg-gray-100 object-cover">
                    {% else %}
                    <div class="mb-2 flex h-[52px] w-[52px] items-center justify-center rounded-full bg-gray-100 text-xs font-bold text-gray-500">{{ starting_pitchers.away.label }}</div>
                    {% endif %}
                    <div class="flex items-baseline justify-center gap-1.5">
                        <span class="text-[15px] font-bold leading-tight text-gray-800">{{ starting_pitchers.away.display_name }}</span>
                        <span class="text-[11px] font-bold text-gray-500">{{ starting_pitchers.away.hand_short }}</span>
                    </div>
                </div>

                <div class="flex flex-col items-center text-center">
                    <span class="mb-2 text-[11px] font-bold tracking-wider text-gray-500">{{ starting_pitchers.home.label }}</span>
                    {% if starting_pitchers.home.avatar_url %}
                    <img src="{{ starting_pitchers.home.avatar_url }}" alt="{{ starting_pitchers.home.full_name }}" class="mb-2 h-[52px] w-[52px] rounded-full bg-gray-100 object-cover">
                    {% else %}
                    <div class="mb-2 flex h-[52px] w-[52px] items-center justify-center rounded-full bg-gray-100 text-xs font-bold text-gray-500">{{ starting_pitchers.home.label }}</div>
                    {% endif %}
                    <div class="flex items-baseline justify-center gap-1.5">
                        <span class="text-[15px] font-bold leading-tight text-gray-800">{{ starting_pitchers.home.display_name }}</span>
                        <span class="text-[11px] font-bold text-gray-500">{{ starting_pitchers.home.hand_short }}</span>
                    </div>
                </div>
            </div>

            <h2 class="mb-4 mt-6 border-t border-gray-100 pt-6 text-center text-xs font-bold uppercase tracking-widest text-gray-400">Starting Lineups</h2>
            <div class="grid grid-cols-2 gap-8 px-2">
                <div class="flex flex-col">
                    <div class="mb-3 border-b border-gray-100 pb-2 text-[12px] font-bold tracking-wider text-gray-800">{{ starting_lineups.away.label }}</div>
                    <ul class="flex flex-col gap-2.5">
                        {% for player in starting_lineups.away.players %}
                        <li class="flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <span class="w-2 text-sm font-medium text-gray-400">{{ player.order }}</span>
                                <span class="text-[14px] font-semibold text-gray-800">{{ player.display_name }}</span>
                            </div>
                            {% if player.position %}
                            <span class="text-[11px] font-bold text-gray-500">{{ player.position }}</span>
                            {% endif %}
                        </li>
                        {% endfor %}
                    </ul>
                </div>

                <div class="flex flex-col">
                    <div class="mb-3 border-b border-gray-100 pb-2 text-[12px] font-bold tracking-wider text-gray-800">{{ starting_lineups.home.label }}</div>
                    <ul class="flex flex-col gap-2.5">
                        {% for player in starting_lineups.home.players %}
                        <li class="flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <span class="w-2 text-sm font-medium text-gray-400">{{ player.order }}</span>
                                <span class="text-[14px] font-semibold text-gray-800">{{ player.display_name }}</span>
                            </div>
                            {% if player.position %}
                            <span class="text-[11px] font-bold text-gray-500">{{ player.position }}</span>
                            {% endif %}
                        </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </div>

        {% for section in sections %}
        <section class="rounded-xl bg-white p-6 shadow-sm">
            <h1 class="mb-8 border-t border-gray-100 pt-8 text-3xl font-extrabold">{{ section.title }}</h1>

            <div class="flex flex-col gap-8">
                {% for play in section.plays %}
                {% if play.layout == "stolen_base" %}
                <div class="flex items-start gap-4">
                    <div class="flex h-[52px] w-[52px] shrink-0 items-center justify-center rounded-full border border-gray-200 bg-white">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400">
                            <path d="M19 14l-4-4H8L4 12v3a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-1z" />
                            <path d="M2 10h4" />
                            <path d="M1 14h3" />
                        </svg>
                    </div>

                    <div class="flex flex-col justify-center pt-0.5">
                        <span class="mb-0.5 text-sm font-bold text-gray-500">{{ play.event }}</span>
                        <p class="text-[17px] leading-snug">
                            {{ play.description }}
                            {% if play.out_text %}
                            <span class="font-bold">{{ play.out_text }}</span>
                            {% endif %}
                        </p>
                    </div>
                </div>
                {% elif play.layout == "pitching_substitution" %}
                <div class="flex items-start gap-4">
                    <div class="flex h-[52px] w-[52px] shrink-0 items-center justify-center rounded-full border border-gray-200 bg-white">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-6 h-6 text-gray-500">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9H5m0 0l3.5-3.5M5 9l3.5 3.5" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 15h14m0 0l-3.5-3.5M19 15l-3.5 3.5" />
                        </svg>
                    </div>

                    <div class="flex flex-col justify-center pt-0.5">
                        <span class="mb-0.5 text-sm font-bold text-gray-500">{{ play.event }}</span>
                        <p class="text-[17px] leading-snug">
                            {{ play.description }}
                            {% if play.out_text %}
                            <span class="font-bold">{{ play.out_text }}</span>
                            {% endif %}
                        </p>
                    </div>
                </div>
                {% else %}
                <div class="flex items-start gap-4">
                    {% if play.avatar_url %}
                    <img src="{{ play.avatar_url }}" alt="{{ play.avatar_alt }}" class="h-[52px] w-[52px] shrink-0 rounded-full border border-gray-200 object-cover">
                    {% else %}
                    <div class="flex h-[52px] w-[52px] shrink-0 items-center justify-center rounded-full border border-gray-200 bg-white text-sm font-bold text-gray-500">
                        {{ play.avatar_text }}
                    </div>
                    {% endif %}

                    <div class="flex flex-col items-start pt-0.5">
                        {% if play.base_out_state %}
                        <div class="mb-2 flex items-center gap-2">
                            <svg width="22" viewBox="0 0 24 17.25" class="text-black">
                                <rect fill="{% if play.base_out_state.third %}currentColor{% else %}transparent{% endif %}" stroke-width="1.5" stroke="currentColor" width="6" height="6" transform="translate(5.25, 7.25) rotate(-315)"></rect>
                                <rect fill="{% if play.base_out_state.second %}currentColor{% else %}transparent{% endif %}" stroke-width="1.5" stroke="currentColor" width="6" height="6" transform="translate(12, 0.75) rotate(-315)"></rect>
                                <rect fill="{% if play.base_out_state.first %}currentColor{% else %}transparent{% endif %}" stroke-width="1.5" stroke="currentColor" width="6" height="6" transform="translate(18.75, 7.25) rotate(-315)"></rect>
                            </svg>
                            <span class="mt-0.5 text-sm font-semibold leading-none text-gray-900">{{ play.base_out_state.outs_text }}</span>
                            {% if play.current_score_text %}
                            <span class="mt-0.5 text-sm font-semibold leading-none text-gray-900">{{ play.current_score_text }}</span>
                            {% endif %}
                        </div>
                        {% endif %}

                        <span class="badge-blue mb-1.5 inline-flex rounded-full border px-3 py-0.5 text-[13px] font-semibold">
                            {{ play.event }}
                        </span>

                        <p class="text-[17px] leading-snug text-gray-900">
                            {{ play.description }}
                            {% if play.out_text %}
                            <span class="font-bold">{{ play.out_text }}</span>
                            {% endif %}
                        </p>

                        {% if play.score_update %}
                        <p class="mt-4 text-[17px] text-gray-900">
                            {% if play.score_update.leading_team == "away" %}
                            <span class="font-extrabold">{{ away_label }} {{ play.score_update.away_score }}</span>, {{ home_label }} {{ play.score_update.home_score }}
                            {% elif play.score_update.leading_team == "home" %}
                            {{ away_label }} {{ play.score_update.away_score }}, <span class="font-extrabold">{{ home_label }} {{ play.score_update.home_score }}</span>
                            {% else %}
                            {{ away_label }} {{ play.score_update.away_score }}, {{ home_label }} {{ play.score_update.home_score }}
                            {% endif %}
                        </p>
                        {% endif %}
                    </div>
                </div>
                {% endif %}
                {% endfor %}
            </div>
        </section>
        {% endfor %}
    </div>
</body>
</html>
